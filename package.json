{
  "name": "personal-hub",
  "version": "0.1.34",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint .",
    "check:client-env": "node scripts/check-client-env.mjs",
    "check:supabase-cors": "node scripts/check-supabase-cors.mjs",
    "check:p0": "npm run check:client-env && npm run check:supabase-cors",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-email/components": "^1.0.10",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.4",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.499.0",
    "minio": "^8.0.7",
    "next": "^15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,mjs}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "bash -c 'cd \"$(git rev-parse --show-toplevel)\" && npx next lint --file \"$@\"' --"
    ]
  }
}
