# App
NEXT_PUBLIC_APP_VERSION=0.1.14

# NextAuth — AUTH_URL = твій публічний домен (через Cloudflare Tunnel)
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=https://your-domain.com

# Postgres (внутрішній хост — "postgres" це ім'я сервісу в compose)
DATABASE_URL=postgres://hub:change_me@postgres:5432/personal_hub
POSTGRES_USER=hub
POSTGRES_PASSWORD=change_me
POSTGRES_DB=personal_hub

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Email (Resend.com — безкоштовно 3000 листів/місяць)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@your-domain.com
ADMIN_EMAIL=your@email.com

# Ліміт активних користувачів
MAX_ACTIVE_USERS=50
